  {
	"bg": "#e8d7a5",
	"illustration": "res://assets/images/opening_decesnt.png",
	"speed": 2.0,
	"speaker": "",
	"text": "斷裂的線頭，在視線中緩慢地揚起。"
  },
  {
	"bg": "#292a3b",
	"illustration": "res://assets/images/opening_decesnt.png",
	"speed": 1.0,
	"speaker": "",
	"text": "「不要──！」"

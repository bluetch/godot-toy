[gd_scene format=3 uid="uid://c0swrriuwgntu"]

[sub_resource type="GDScript" id="GDScript_fapxi"]
script/source = "extends CanvasLayer

@onready var background: ColorRect = $Background
@onready var panel_bg: ColorRect = $Control/PanelBg
@onready var speaker_label: Label = $Control/PanelBg/Speaker
@onready var text_label: Label = $Control/PanelBg/TextLabel
@onready var arrow: Label = $Control/PanelBg/Arrow

const CHAR_DELAY = 0.035

var BEATS: Array = []

# 現在在第幾個beat
var _current_beat: int = 0
# 這個beat的完整台詞
var _full_text: String = \"\"
# 打字機目前打到第幾個字
var _char_index: int = 0
# 是否還在打字中
var _is_typing: bool = false
# 背景tween進行中時所著輸入
var _can_input: bool = false
# 防止結束動作被觸發兩次
var _ending: bool = false

func _ready() -> void:
	panel_bg.visible = false
	background.color = Color.BLACK
	_load_beats_from_json()
	if BEATS.size() > 0:
		_show_beat(0)

func _load_beats_from_json() -> void:
	var file = FileAccess.open(\"res://assets/data/opening.json\", FileAccess.READ)
	if file:
		var content = file.get_as_text()
		var json_data = JSON.parse_string(content)
		if typeof(json_data) == TYPE_ARRAY:
			for item in json_data:
				if item.has(\"bg\") and typeof(item[\"bg\"]) == TYPE_STRING:
					item[\"bg\"] = Color(item[\"bg\"])
				BEATS.append(item)
	
func _show_beat(index: int) -> void:
	var beat = BEATS[index]
	
	# 背景顏色漸變照常執行，但「不要」等待它完成，這樣玩家點擊時就不會覺得卡卡的
	var tween = create_tween()
	tween.tween_property(background, \"color\", beat.get(\"bg\", Color.BLACK), 0.3)
	
	if not panel_bg.visible:
		panel_bg.visible = true
		
	var speaker_name = beat.get(\"speaker\", \"\")
	speaker_label.text = speaker_name
		
	_full_text = beat[\"text\"]
	_char_index = 0
	_is_typing = true
	arrow.visible = false
	text_label.text = \"\"
	_can_input = true
	_type_next_char()

func _type_next_char() -> void:
	if not _is_typing:
		return	
	if _char_index < _full_text.length():
		_char_index += 1
		text_label.text = _full_text.left(_char_index)
		get_tree().create_timer(CHAR_DELAY).timeout.connect(_type_next_char, CONNECT_ONE_SHOT)
	else:
		_is_typing = false
		arrow.visible = true
		
func _finish_typing() -> void:
	_is_typing = false
	text_label.text = _full_text
	arrow.visible = true
	
func _input(event: InputEvent) -> void:
	# Escape 不受 _can_input 限制，隨時可以跳過整個開場
	if event is InputEventKey and event.pressed and event.keycode == KEY_ESCAPE:
		_end_cutscene()
		return

	# 背景 tween 進行中時鎖住輸入，避免玩家亂按跳過動畫
	if not _can_input:
		return
	if not (event is InputEventKey and event.pressed) and \\
	   not (event is InputEventMouseButton and event.pressed):
		return

	# 還在打字中：快進到完整文字，不跳下一句
	if _is_typing:
		_finish_typing()
		return

	# 已打完：推進到下一個 beat，或結束過場
	_current_beat += 1
	if _current_beat >= BEATS.size():
		_end_cutscene()
	else:
		_show_beat(_current_beat)

func _end_cutscene() -> void:
	if _ending:
		return
	_ending = true
	_can_input = false
	var tween = create_tween()
	tween.tween_property(background, \"color\", Color.BLACK, 1.0)
	await tween.finished
	get_tree().change_scene_to_file(\"res://scenes/game.tscn\")
"

